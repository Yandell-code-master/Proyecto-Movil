<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AplicacionMovil.BigFood_Facturas"
             Title="Historial de Ventas"
             BackgroundColor="#F4F6F9">

    <Grid RowDefinitions="Auto, *">

        <StackLayout Grid.Row="0" BackgroundColor="#8B3A1E" Padding="20,15">
            <Label Text="BIG FOOD SERVICES, S.A."
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center" />
            <Label Text="Control Digital de Facturas"
                   TextColor="#E0E0E0"
                   FontSize="14"
                   HorizontalOptions="Center" />
        </StackLayout>

        <CollectionView Grid.Row="1" 
                        x:Name="ListaFacturas"
                        Margin="15,10">

            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="30">
                    <ActivityIndicator IsRunning="True" Color="#8B3A1E" HeightRequest="40" HorizontalOptions="Center"/>
                    <Label Text="Cargando facturas desde el servidor..." 
                           TextColor="Gray" 
                           HorizontalOptions="Center" 
                           Margin="0,10,0,0"/>
                </StackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="LightGray"
                            BackgroundColor="White"
                            Margin="0,0,0,12"
                            Padding="15">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.1"/>
                        </Border.Shadow>

                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="*, *">

                            <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="5">
                                <Label Text="Factura:" FontAttributes="Bold" TextColor="Gray" FontSize="13"/>
                                <Label Text="{Binding Numero}" FontAttributes="Bold" TextColor="Black" FontSize="14"/>
                            </StackLayout>

                            <Border Grid.Row="0" Grid.Column="1" 
                                    HorizontalOptions="End" 
                                    BackgroundColor="#E8F5E9" 
                                    StrokeShape="RoundRectangle 5" 
                                    Padding="8,2"
                                    StrokeThickness="0">
                                <Label Text="{Binding Estado}" 
                                       TextColor="#2E7D32" 
                                       FontAttributes="Bold" 
                                       FontSize="11"/>
                            </Border>

                            <StackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8" Spacing="3">
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Cliente ID:" TextColor="Gray" FontSize="13"/>
                                    <Label Text="{Binding CedulaCliente}" TextColor="Black" FontSize="13" FontAttributes="Bold"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Fecha:" TextColor="Gray" FontSize="12"/>
                                    <Label Text="{Binding Fecha, StringFormat='{0:dd/MM/yyyy hh:mm tt}'}" TextColor="Black" FontSize="12"/>
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="Cajero ID:" TextColor="Gray" FontSize="12"/>
                                    <Label Text="{Binding UsuarioId}" TextColor="Black" FontSize="12"/>
                                </HorizontalStackLayout>
                            </StackLayout>

                            <BoxView Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" HeightRequest="1" Color="#F0F0F0" Margin="0,5"/>

                            <StackLayout Grid.Row="2" Grid.Column="0" VerticalOptions="End">
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="Sub:" TextColor="Gray" FontSize="11"/>
                                    <Label Text="{Binding Subtotal, StringFormat='¢{0:N2}'}" TextColor="DarkSlateGray" FontSize="11"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="I.V.A:" TextColor="Gray" FontSize="11"/>
                                    <Label Text="{Binding MontoImpuesto, StringFormat='¢{0:N2}'}" TextColor="DarkSlateGray" FontSize="11"/>
                                </HorizontalStackLayout>
                            </StackLayout>

                            <StackLayout Grid.Row="2" Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center">
                                <Label Text="TOTAL" HorizontalOptions="End" FontSize="10" TextColor="Gray" FontAttributes="Bold"/>
                                <Label Text="{Binding Total, StringFormat='¢{0:N2}'}" 
                                       TextColor="#8B3A1E" 
                                       FontSize="16" 
                                       FontAttributes="Bold"/>
                            </StackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>